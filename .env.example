# ─────────────────────────────────────────────────────────────────
#  Turso Database (Required for Vercel production)
#  Get these from: https://turso.tech (free tier)
#  Steps:
#    1. Create account at turso.tech
#    2. Run: turso db create portfolio-admin
#    3. Run: turso db show portfolio-admin  → copy URL
#    4. Run: turso db tokens create portfolio-admin → copy token
#    5. Add both below to Vercel Environment Variables
# ─────────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ─────────────────────────────────────────────────────────────────
#  JWT Secret (optional — a default is used if not set)
#  Recommended to set your own strong secret in Vercel
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=brijesh_super_secret_jwt_key_2024_portfolio_admin
